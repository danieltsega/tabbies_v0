{
  "manifest_version": 3,
  "name": "Tabbies",
  "version": "0.1.0",
  "description": "Save and organize your tabs in categories with zero-reload history preservation.",
  "key": "",
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3000/"
  ],
  "omnibox": {
    "keyword": "tabbies"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Tabbies popup"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabbies"
  },
  "web_accessible_resources": [
    {
      "resources": ["anchor.html", "anchor.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
